{
  "name": "robotstreamer",
  "version": "1.1.0",
  "description": "RobotStreamer — stream your robot live",
  "main": "main.js",
  "dependencies": {
    "colors": "^1.4.0",
    "electron-context-menu": "^3.6.1",
    "electron-store": "^8.1.0",
    "node-media-server": "2.6.2",
    "say": "^0.16.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.robotstreamer.app",
    "productName": "RobotStreamer",
    "directories": { "output": "dist" },
    "files": ["**/*", "!release-builds/**", "!dist/**", "!.github/**"],
    "mac": {
      "icon": "assets/icons/mac/icon.icns",
      "category": "public.app-category.utilities",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "dmg": {
      "title": "Install RobotStreamer",
      "contents": [
        { "x": 410, "y": 150, "type": "link", "path": "/Applications" },
        { "x": 130, "y": 150, "type": "file" }
      ]
    },
    "win": {
      "icon": "assets/icons/win/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
